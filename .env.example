# ─── Telegram ─────────────────────────────────────────────────────────────────
# Token do bot (obtenha com @BotFather no Telegram)
TELEGRAM_BOT_TOKEN=

# Seu chat ID pessoal (o bot só responde a este ID)
# Para descobrir: envie /start para @userinfobot no Telegram
TELEGRAM_CHAT_ID=

# ─── X (Twitter) ──────────────────────────────────────────────────────────────
# Crie um projeto em developer.twitter.com e gere as credenciais abaixo.
# O app precisa de permissão de Read AND Write.

# API Key (Consumer Key)
X_CLIENT_ID=

# API Key Secret (Consumer Secret)
X_CLIENT_SECRET=

# Access Token (gerado para sua conta)
X_ACCESS_TOKEN=

# Access Token Secret
X_ACCESS_TOKEN_SECRET=

# Seu @username no X (sem o @) — usado para gerar link do tweet
# Deixe em branco se não quiser link direto
X_USERNAME=

# ─── LinkedIn ─────────────────────────────────────────────────────────────────
# Crie um app em https://developer.linkedin.com
# Escopos necessários: w_member_social + r_liteprofile (OpenID Connect)
# Siga o fluxo OAuth 2.0 para gerar um access token de 60 dias.
# Renovação: repita o fluxo OAuth ou use um proxy de refresh (ex: Pizzly/Nango).

# Access Token (OAuth 2.0 Bearer — expira em 60 dias)
LINKEDIN_ACCESS_TOKEN=

# URN do seu perfil — opcional, preencher evita uma chamada extra à API.
# Formato: urn:li:person:XXXXXXXXXX
# Para descobrir: acesse https://www.linkedin.com/in/seu-perfil e veja o ID na URL
# Ou deixe em branco — o agente busca automaticamente via /v2/me
LINKEDIN_PERSON_URN=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Banco de dados ───────────────────────────────────────────────────────────
# URL de conexão PostgreSQL.
# No Railway: o addon PostgreSQL injeta DATABASE_URL automaticamente.
# Formato: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/elon

# ─── Pesquisa automática (RSS + X) ────────────────────────────────────────────
# "true"  = busca RSS e X antes de cada post autônomo (recomendado)
# "false" = desativa pesquisa (posts usam apenas /contexto e histórico)
RESEARCH_ENABLED=true

# ─── Modo autônomo ────────────────────────────────────────────────────────────
# "true"  = posts publicados direto no X sem aprovação
# "false" = posts enviados ao Telegram para aprovação antes de publicar
# Pode ser alterado em runtime com /auto on e /auto off
AUTONOMOUS_MODE=false

# ─── Porta HTTP ───────────────────────────────────────────────────────────────
# Railway injeta $PORT automaticamente. Não precisa alterar.
PORT=3000
